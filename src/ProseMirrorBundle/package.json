{
  "name": "silentnotes-prosemirror",
  "version": "1.0.0",
  "description": "Transpiles and bundles the required JS files of ProseMirror for SilentNotes",
  "repository": {
    "type": "git",
    "url": "https://github.com/martinstoeckli/SilentNotes"
  },
  "scripts": {
    "build": "esbuild src/prose-mirror-bundle.ts --bundle --minify --tsconfig-raw=true --format=esm --keep-names --tree-shaking=true --target=es2020,chrome67,edge18,firefox60,node12 --outfile=../SilentNotes.Blazor/wwwroot/prose-mirror-bundle.js",
    "debug": "esbuild src/prose-mirror-bundle.ts --bundle --tsconfig-raw=true --format=esm --keep-names --tree-shaking=true --target=es2020,chrome67,edge18,firefox60,node12 --outfile=../SilentNotes.Blazor/wwwroot/prose-mirror-bundle.js"
  },
  "keywords": [],
  "author": "Martin Stoeckli",
  "license": "MPL-2.0",
  "devDependencies": {
    "core-js": "latest",
    "typescript": "latest"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.2",
    "@tiptap/extension-blockquote": "^3.27.2",
    "@tiptap/extension-bold": "^3.27.2",
    "@tiptap/extension-code": "^3.27.2",
    "@tiptap/extension-code-block": "^3.27.2",
    "@tiptap/extension-code-block-lowlight": "^3.27.2",
    "@tiptap/extension-document": "^3.27.2",
    "@tiptap/extension-hard-break": "^3.27.2",
    "@tiptap/extension-heading": "^3.27.2",
    "@tiptap/extension-history": "^3.27.2",
    "@tiptap/extension-horizontal-rule": "^3.27.2",
    "@tiptap/extension-italic": "^3.27.2",
    "@tiptap/extension-link": "^3.27.2",
    "@tiptap/extension-list": "^3.27.2",
    "@tiptap/extension-paragraph": "^3.27.2",
    "@tiptap/extension-strike": "^3.27.2",
    "@tiptap/extension-text": "^3.27.2",
    "@tiptap/extension-text-style": "^3.27.2",
    "@tiptap/extension-underline": "^3.27.2",
    "@tiptap/markdown": "^3.27.2",
    "esbuild": "latest"
  }
}
